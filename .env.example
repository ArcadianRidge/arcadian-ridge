# Arcadian Ridge Postgres
DATABASE_URL=postgresql://user:pass@localhost:5432/arcadian_ridge
ARCR_TENANT_ID=
ARCR_TOKEN_ENCRYPTION_KEY=

# Console + inbound URLs
ARCR_CONSOLE_URL=http://localhost:3200
ARCR_INBOUND_URL=http://localhost:4400
PUBLIC_ARCR_CONSOLE_API=http://localhost:3200

# Rak bridge (inference + alerts)
RAK_GATEWAY_URL=http://localhost:8787
RAKONTEVR_GATEWAY_URL=
RAK_BUILDERHUB_URL=http://localhost:3000
RAK_API_KEY=
RAK_DEFAULT_TENANT_ID=
RAK_DEFAULT_USER_ID=
ARCR_LYRA_ORCHESTRATION=0
ARCR_LYRA_REQUIRED=0
OPENCLAW_URL=
OPENCLAW_TOKEN=
ARCR_OPENCLAW_CHANNEL=http

# County project metering
ARCR_DEFAULT_PROJECT_ID=arcadian-ridge

# Vendor adapters (simulator by default)
ARCR_SKIP_PROVIDER=simulator
ARCR_PRINT_PROVIDER=simulator
ARCR_RON_PROVIDER=simulator
ARCR_PACER_PROVIDER=simulator

# Envelope defaults (cents per county per month)
ARCR_DATA_ENVELOPE_CENTS=50000
ARCR_MAIL_ENVELOPE_COUNT=500
